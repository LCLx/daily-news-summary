# Email summary backend.
# BEDROCK_CLAUDE uses AWS credentials/role. CLAUDE_API uses ANTHROPIC_API_KEY.
# CLAUDE_CLI and CODEX_CLI use your local CLI login.
BACKEND=CODEX_CLI

# Optional backend model/alias.
# Bedrock Claude default: us.anthropic.claude-haiku-4-5-20251001-v1:0
# Claude API default: claude-haiku-4-5-20251001
# Claude CLI default: haiku
# Codex CLI default: your local Codex config if MODEL is empty.
# For local Codex-backed testing, set a cheaper model explicitly so it does
# not inherit a high-end global Codex default.
MODEL=gpt-5.4-mini

# Optional local test mode: limits the digest to 1 article per category.
MODE=TEST

# Required only for BACKEND=BEDROCK_CLAUDE.
AWS_REGION=us-east-1

# Required only for BACKEND=CLAUDE_API.
ANTHROPIC_API_KEY=

# Gmail SMTP delivery.
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_TO=

# Optional Gmail API delivery mode. Not needed for the current GitHub Actions SMTP path.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Telegram pipeline.
OPENCLAW_CONFIG=
TELEGRAM_CHAT_ID=
